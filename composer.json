{
  "name": "dillonsmart/tetherphp",
  "type": "project",
  "description": "TetherPHP is a PHP framework which ships as a skeleton application.",
  "keywords": [
    "tetherphp",
    "framework"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.4"
  },
  "autoload": {
    "psr-4": {
      "TetherPHP\\": "src/",
      "Actions\\": "app/Actions/",
      "Responders\\": "app/Responders/",
      "Domains\\": "app/Domains/",
      "Views\\": "app/Views/"
    },
    "files": [
      "src/framework/Helpers/GlobalFunctions.php"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
